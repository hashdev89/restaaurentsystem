# On Vercel: add these in Project Settings → Environment Variables, then redeploy.
# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only: needed for System Dashboard (add restaurant, delete restaurant, login). Get from Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Optional: UUID of the default restaurant in Supabase (for orders API when using rest_1)
NEXT_PUBLIC_DEFAULT_RESTAURANT_ID=your_restaurant_uuid_from_supabase

# Restaurant login (session signing) – set a secret (min 8 characters; 16+ recommended)
AUTH_SECRET=your_secret_min_8_characters

# Stripe (payments) – get from https://dashboard.stripe.com/test/apikeys
# Use test keys for testing (pk_test_..., sk_test_...). Test card: 4242 4242 4242 4242
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
# Optional: for webhooks – run: stripe listen --forward-to localhost:3000/api/stripe/webhook
# STRIPE_WEBHOOK_SECRET=whsec_...
