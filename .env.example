# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only: needed for delete restaurant (bypasses RLS). Get from Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Optional: UUID of the default restaurant in Supabase (for orders API when using rest_1)
NEXT_PUBLIC_DEFAULT_RESTAURANT_ID=your_restaurant_uuid_from_supabase

# Restaurant login (session signing) – set a secret (min 8 characters; 16+ recommended)
AUTH_SECRET=your_secret_min_8_characters

# Square API Configuration
NEXT_PUBLIC_SQUARE_APPLICATION_ID=your_square_application_id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your_square_location_id
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=your_square_access_token
